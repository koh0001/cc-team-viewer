{
  "name": "cc-team-viewer-vscode",
  "displayName": "CC Team Viewer",
  "description": "Claude Code Agent Teams 실시간 모니터링 — VS Code 확장",
  "version": "0.1.0",
  "publisher": "cc-team-viewer",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onView:ccTeamViewer.treeView",
    "workspaceContains:**/.claude"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ccTeamViewer.openDashboard",
        "title": "CC Team Viewer: Open Dashboard",
        "icon": "$(telescope)"
      },
      {
        "command": "ccTeamViewer.refresh",
        "title": "CC Team Viewer: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "ccTeamViewer.selectTeam",
        "title": "CC Team Viewer: Select Team"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cc-team-viewer",
          "title": "CC Team Viewer",
          "icon": "$(telescope)"
        }
      ]
    },
    "views": {
      "cc-team-viewer": [
        {
          "id": "ccTeamViewer.treeView",
          "name": "Teams"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "ccTeamViewer.openDashboard",
          "when": "view == ccTeamViewer.treeView",
          "group": "navigation"
        },
        {
          "command": "ccTeamViewer.refresh",
          "when": "view == ccTeamViewer.treeView",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "package": "vsce package --no-dependencies"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/koh0001/cc-team-viewer.git",
    "directory": "packages/vscode"
  },
  "homepage": "https://github.com/koh0001/cc-team-viewer#readme",
  "bugs": {
    "url": "https://github.com/koh0001/cc-team-viewer/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@cc-team-viewer/core": "*"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0"
  }
}
