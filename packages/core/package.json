{
  "name": "@cc-team-viewer/core",
  "version": "0.1.0",
  "description": "Real-time monitoring library for Claude Code Agent Teams — file watching, JSON parsing, events",
  "keywords": ["claude-code", "agent-teams", "monitoring", "dashboard", "developer-tools"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.6.0"
  },
  "files": ["dist"]
}
